{
  "name": "ra2web-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @ra2/web dev",
    "build": "pnpm --filter @ra2/web build",
    "preview": "pnpm --filter @ra2/web preview",
    "typecheck:entry": "pnpm --filter @ra2/web typecheck:entry",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:baseline": "node scripts/check-typecheck-baseline.mjs",
    "bundle:baseline": "pnpm build && node scripts/check-bundle-baseline.mjs",
    "lint": "eslint packages apps/web/src",
    "lint:boundaries": "eslint packages apps/web/src --rule '{\"boundaries/element-types\":\"error\"}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "live:runtime": "node scripts/live-interaction-runtime.mjs",
    "live:runtime:build": "pnpm build && node scripts/live-interaction-runtime.mjs",
    "fetch:gamepack": "node scripts/fetch-gamepack.mjs",
    "debug:test-entries": "node scripts/test-entry-flow.mjs",
    "debug:tester-panels": "node scripts/tester-panel-flow.mjs",
    "debug:viewport": "node scripts/viewport-flow.mjs",
    "debug:options": "node scripts/options-flow.mjs",
    "debug:storage-explorer": "node scripts/storage-explorer-flow.mjs",
    "debug:game-res-init": "node scripts/game-res-init-flow.mjs",
    "debug:skirmish-lobby-data": "node scripts/skirmish-lobby-data-flow.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-plugin-boundaries": "^5.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "three": "0.183.2"
    }
  }
}
